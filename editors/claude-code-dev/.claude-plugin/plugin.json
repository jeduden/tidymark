{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "mdsmith-dev-lsp",
  "description": "Code intelligence for mdsmith contributors: gopls for Go (cmd/, internal/), typescript-language-server for the VS Code extension (editors/vscode/), and the stable @mdsmith/cli LSP for the repo's own Markdown.",
  "homepage": "https://github.com/jeduden/mdsmith",
  "repository": "https://github.com/jeduden/mdsmith",
  "license": "MIT",
  "keywords": ["development", "lsp", "go", "typescript", "markdown"],
  "lspServers": {
    "mdsmith": {
      "command": "npx",
      "args": ["-y", "-p", "@mdsmith/cli", "mdsmith", "lsp"],
      "extensionToLanguage": {
        ".md": "markdown",
        ".markdown": "markdown"
      }
    },
    "gopls": {
      "command": "gopls",
      "extensionToLanguage": {
        ".go": "go"
      }
    },
    "typescript": {
      "command": "npx",
      "args": [
        "-y",
        "-p", "typescript-language-server",
        "-p", "typescript",
        "typescript-language-server",
        "--stdio"
      ],
      "extensionToLanguage": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact"
      }
    }
  }
}
